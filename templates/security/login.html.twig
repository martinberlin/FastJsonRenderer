{% extends 'base.html.twig' %}

{% block title %}Sign In — FastJsonRenderer{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body {
            background: #0f1117;
            color: #e2e8f0;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }
        .login-card {
            background: #1a1d27;
            border: 1px solid #2d3150;
            border-radius: 12px;
            padding: 2.5rem 3rem;
            max-width: 380px;
            width: 100%;
            text-align: center;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        }
        .login-card h1 {
            font-size: 1.6rem;
            margin: 0 0 0.4rem;
            color: #f0f4ff;
        }
        .login-card .subtitle {
            color: #8892b0;
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }
        .btn-github {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            background: #238636;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 0.75rem 1.5rem;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
            width: 100%;
            justify-content: center;
        }
        .btn-github:hover { background: #2ea043; }
        .btn-github svg { width: 20px; height: 20px; fill: currentColor; }
        .login-note {
            margin-top: 1.5rem;
            font-size: 0.8rem;
            color: #8892b0;
        }
        .back-link {
            display: inline-block;
            margin-top: 1rem;
            color: #8892b0;
            text-decoration: none;
            font-size: 0.85rem;
        }
        .back-link:hover { color: #e2e8f0; }
    </style>
{% endblock %}

{% block body %}
    <div class="login-card">
        <h1>🖥 FastJsonRenderer</h1>
        <p class="subtitle">Sign in to save your ePaper screen designs</p>

        <a href="{{ path('connect_github_start') }}" class="btn-github">
            <svg viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                         0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
                         -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
                         .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
                         -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 2-.27
                         c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
                         .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
                         0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8
                         c0-4.42-3.58-8-8-8z"/>
            </svg>
            Sign in with GitHub
        </a>

        <p class="login-note">
            Signing in lets you save screens and use the G5 image import feature.<br>
            Without signing in you can still draw and send via BLE.
        </p>

        <a href="{{ path('app_index') }}" class="back-link">← Continue without signing in</a>
    </div>
{% endblock %}
